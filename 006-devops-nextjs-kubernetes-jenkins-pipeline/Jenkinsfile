pipeline {  // Jenkins CI/CD pipeline tanımı başlatılır
    agent any  // Pipeline herhangi bir Jenkins agent üzerinde çalışabilir

    tools {  // Kullanılacak araçlar burada tanımlanır
        jdk 'Java21'  // Java 21 JDK ortamı kullanılır
        nodejs 'NodeJS24'  // Node.js 24 runtime ortamı kullanılır
    }

    environment {  // Pipeline genel değişkenleri tanımlanır
        APP_NAME = "006-devops-nextjs-kubernetes-jenkins-pipeline"  // Uygulama adı değişkene atanır
        RELEASE = "1.0.${env.BUILD_NUMBER}"  // Her build için versiyon numarası oluşturulur
        DOCKER_USER = "huseyin11"  // Docker Hub kullanıcı adı belirlenir
        DOCKER_PASS = 'DockerHubTokenForJenkinsText'  // Docker erişim token credential ID olarak tanımlanır
        IMAGE_NAME = "${DOCKER_USER}/${APP_NAME}"  // Docker image adı oluşturulur
        IMAGE_TAG = "${RELEASE}"  // Docker image tag’i build numarasına göre belirlenir
        SCANNER_HOME = tool "SonarQubeScanner"  // SonarQube scanner path’i alınır
    }

    stages {  // CI/CD pipeline aşamaları başlar

        stage('🧹 Workspace Temizleme | Clean Workspace') {  // Çalışma alanı temizlenir
            steps {
                cleanWs()  // Jenkins workspace içeriği silinir
            }
        }

        /*stage('📥 Kaynak Kod Alma | SCM GitHub Checkout') {  // GitHub reposundan kod çekilir
            steps {
                checkout scmGit(
                    branches: [[name: '/main']],  // Main branch seçilir
                    extensions: [],  // Ek Git extension kullanılmaz
                    userRemoteConfigs: [[url: 'https://github.com/huseyinaydin99/devops/006-devops-nextjs-kubernetes-jenkins-pipeline']]  // Repo URL’si
                )
            }
        }*/

        stage('📥 Kaynak Kod Alma | SCM GitHub Checkout') {
            steps {
                script {
                    sh """
                    git init
                    git remote add origin https://github.com/huseyinaydin99/devops.git
                    git config core.sparseCheckout true
                    echo "006-devops-nextjs-kubernetes-jenkins-pipeline/*" >> .git/info/sparse-checkout
                    git pull origin main
                    """
                }
            }
        }

        stage('📦 Bağımlılık Kurulumu | Install Dependencies') {  // Node.js bağımlılıkları yüklenir
            steps {
                script {
                    dir('006-devops-nextjs-kubernetes-jenkins-pipeline') {
                        if (isUnix()) {
                            sh "npm install"
                        } else {
                            bat "npm install"
                        }
                    }
                }
            }
        }

        stage('🔍 Kod Analizi | SonarQube Scan') {  // Kod kalitesi analizi yapılır
            steps {
                script {
                    def scannerHome = tool 'SonarQubeScanner'  // Sonar scanner yolu alınır
                    withSonarQubeEnv('MySonarQubeServer') {  // SonarQube bağlantısı açılır
                        sh """
                        ${scannerHome}/bin/sonar-scanner \  // Sonar scanner çalıştırılır
                        -Dsonar.projectKey=006-devops-nextjs-kubernetes-jenkins-pipeline \  // Proje anahtarı
                        -Dsonar.projectName=006-devops-nextjs-kubernetes-jenkins-pipeline  // Proje adı
                        """
                    }
                }
            }
        }

        stage("🚦 Kalite Kapısı | Quality Gate") {  // SonarQube kalite kontrolü yapılır
            steps {
                script {
                    waitForQualityGate abortPipeline: false, credentialsId: 'MySonarQubeServer'  // Quality gate sonucu beklenir
                }
            }
        }

        /*
        stage('🐳 Docker Image Build') {  // Docker image build aşaması (pasif)
            steps {
                script {
                    if (isUnix()) {
                        sh 'docker build -t huseyin11/006-devops-nextjs-kubernetes-jenkins-pipeline:latest  .'  // Image build
                    } else {
                        bat 'docker build -t huseyin11/006-devops-nextjs-kubernetes-jenkins-pipeline:latest  .'  // Windows build
                    }
                }
            }
        }
        */

        stage("🛡️ FS Güvenlik Taraması | Trivy FS Scan") {  // Dosya sistemi güvenlik taraması yapılır
            steps {
                script {
                    sh "trivy fs . > trivyfs.txt"  // Proje dosyaları vulnerability scan edilir
                }
            }
        }

        stage('🧽 Docker Image Temizleme | Docker Image Clean') {  // Gereksiz Docker image’ları temizlenir
            steps {
                script {
                    if (isUnix()) {
                        sh "docker image prune -f"  // Kullanılmayan image’lar silinir
                    } else {
                        bat "docker image prune -f"  // Windows için temizleme
                    }
                }
            }
        }

        stage("🚀 Docker Build & Push | Docker İmaj Build ve Push") {  // Docker image build edilip push edilir
            steps {
                script {
                    withDockerRegistry(credentialsId: 'DockerHubToken4Jenkins', toolName: 'docker') {  // Docker Hub login yapılır
                        dir('006-devops-nextjs-kubernetes-jenkins-pipeline') {
                        sh "docker build -t 006-devops-nextjs-kubernetes-jenkins-pipeline:latest . "  // Image build edilir
                        sh "docker tag 006-devops-nextjs-kubernetes-jenkins-pipeline huseyin11/006-devops-nextjs-kubernetes-jenkins-pipeline:latest "  // Tag eklenir
                        sh "docker push huseyin11/006-devops-nextjs-kubernetes-jenkins-pipeline:latest "  // Docker Hub’a push edilir
                    }
                    }
                }
            }
        }

        stage("🔍 Image Güvenlik Taraması | Trivy Image Scan") {  // Docker image güvenlik taraması yapılır
            steps {
                sh "trivy image 006-devops-nextjs-kubernetes-jenkins-pipeline:latest > trivyimage.txt"  // Image vulnerability scan edilir
            }
        }

        stage("🚀 Docker Run | Container Deploy") {
            steps {
                script {
                    sh """
                    docker stop nextjs-app || true
                    docker rm nextjs-app || true

                    docker pull huseyin11/006-devops-nextjs-kubernetes-jenkins-pipeline:latest

                    docker run -d \
                    --name nextjs-app \
                    -p 3000:3000 \
                    huseyin11/006-devops-nextjs-kubernetes-jenkins-pipeline:latest
                    """
                }
            }
        }

        /*
        stage('☸️ Kubernetes Deploy | Kubernetes’e Dağıtım') {  // Uygulama Kubernetes’e deploy edilir
            steps {
                script {
                    dir('kubernetes') {  // Kubernetes dosyalarının olduğu klasöre girilir
                        withKubeConfig(  // Kubernetes cluster bağlantısı yapılır
                            caCertificate: '',  // CA sertifikası (boş bırakılmış)
                            clusterName: '',  // Cluster adı (boş bırakılmış)
                            contextName: '',  // Context adı (boş bırakılmış)
                            credentialsId: 'kubernetes',  // Kubernetes credential ID
                            namespace: '',  // Namespace (default kullanılabilir)
                            restrictKubeConfigAccess: false,  // kubeconfig erişimi kısıtlanmaz
                            serverUrl: ''  // Kubernetes API URL
                        ) {
                            sh 'kubectl delete --all pods'  // Eski pod’lar silinir
                            sh 'kubectl apply -f deployment.yml'  // Deployment uygulanır
                            sh 'kubectl apply -f service.yml'  // Service uygulanır
                        }
                    }
                }
            }
        }
*/
    }

    post {
        always {
            emailext(
                attachLog: true,
                mimeType: 'text/html',
                subject: "🚀 [${currentBuild.result}] CI/CD PIPELINE REPORT | ${env.JOB_NAME} #${env.BUILD_NUMBER}",

                body: """
                <html>
                <body style="margin:0; padding:0; background:#0b1220; font-family:Arial;">

                <div style="max-width:720px; margin:auto; padding:25px;">

                    <!-- HEADER -->
                    <div style="background:linear-gradient(90deg,#0ea5e9,#22c55e); padding:20px; border-radius:14px; color:white;">
                        <h1 style="margin:0;">🚀 PIPELINE EXECUTION REPORT</h1>
                        <p style="margin:5px 0 0;">Real-time DevOps Monitoring Intelligence</p>
                    </div>

                    <!-- STATUS CARD -->
                    <div style="margin-top:20px; background:#111827; padding:20px; border-radius:14px; border:1px solid #1f2937;">

                        <h2 style="color:#38bdf8;">📊 Build Overview</h2>

                        <p>📦 Project: <b>${env.JOB_NAME}</b></p>
                        <p>🔢 Build Number: <b>#${env.BUILD_NUMBER}</b></p>

                        <p>⚡ Status:
                            <span style="
                                padding:6px 12px;
                                border-radius:8px;
                                background:${currentBuild.result == 'SUCCESS' ? '#16a34a' : '#dc2626'};
                                color:white;
                                font-weight:bold;">
                                ${currentBuild.result}
                            </span>
                        </p>

                    </div>

                    <!-- METRICS PANEL -->
                    <div style="margin-top:20px; background:#0f172a; padding:20px; border-radius:14px; border:1px solid #1f2937;">

                        <h2 style="color:#fbbf24;">📡 Pipeline Intelligence</h2>

                        <ul style="color:#cbd5e1; line-height:1.8;">
                            <li>🕒 Execution Time: ${currentBuild.durationString}</li>
                            <li>🌐 Jenkins URL: <a style="color:#60a5fa;" href="${env.BUILD_URL}">Open Build</a></li>
                            <li>🧪 Trivy FS Scan: Attached</li>
                            <li>🐳 Image Security Scan: Attached</li>
                            <li>📦 Artifact Status: Stored</li>
                        </ul>

                    </div>

                    <!-- ALERT SECTION -->
                    <div style="margin-top:20px; padding:20px; border-radius:14px;
                        background:${currentBuild.result == 'SUCCESS' ? '#052e16' : '#450a0a'};
                        border:1px solid ${currentBuild.result == 'SUCCESS' ? '#16a34a' : '#dc2626'};">

                        <h2 style="color:white;">🚨 System Verdict</h2>

                        <p style="color:#e5e7eb;">
                            ${currentBuild.result == 'SUCCESS'
                                ? 'Pipeline executed successfully. System stable. No anomalies detected. 🟢'
                                : 'Pipeline failure detected. Immediate investigation required. 🔴'}
                        </p>

                    </div>

                    <!-- FOOTER -->
                    <div style="margin-top:20px; text-align:center; color:#64748b; font-size:12px;">
                        DevOps Intelligence Layer • Jenkins Automated Reporting System
                    </div>

                </div>

                </body>
                </html>
                """,

                to: 'huseyinaydin99@gmail.com',
                attachmentsPattern: 'trivyfs.txt,trivyimage.txt'
            )
        }
    }
}
