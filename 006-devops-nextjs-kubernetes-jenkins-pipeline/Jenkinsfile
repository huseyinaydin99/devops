pipeline {
    agent any

    triggers { githubPush() }

    tools {
        jdk 'JDK21'
        nodejs 'NodeJS24'
    }

    environment {
        APP_NAME = "006-devops-nextjs-kubernetes-jenkins-pipeline"
        RELEASE = "1.0.${env.BUILD_NUMBER}"
        DOCKER_USER = "huseyin11"
        DOCKER_PASS = 'DockerHubTokenForJenkinsText'
        IMAGE_NAME = "${DOCKER_USER}/${APP_NAME}"
        IMAGE_TAG = "${RELEASE}"
        SCANNER_HOME = tool "SonarQubeScanner"
    }

    stages {
        stage('🧹 Workspace Temizleme | Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('📥 Kaynak Kod Alma | SCM GitHub Checkout') {
            steps {
                checkout([$class: 'GitSCM',
                    branches: [[name: '*/main']],
                    userRemoteConfigs: [[url: 'https://github.com/huseyinaydin99/devops.git']],
                    extensions: [
                        [$class: 'SparseCheckoutPaths',
                            sparseCheckoutPaths: [[path: '006-devops-nextjs-kubernetes-jenkins-pipeline/']]
                        ]
                    ]
                ])
            }
        }

        stage('📦 Bağımlılık Kurulumu | Install Dependencies') {
            steps {
                script {
                    dir('006-devops-nextjs-kubernetes-jenkins-pipeline') {
                        if (isUnix()) {
                            sh "npm install"
                        } else {
                            bat "npm install"
                        }
                    }
                }
            }
        }

        stage('🔍 Kod Analizi | SonarQube Scan') {
            steps {
                script {
                    def scannerHome = tool 'SonarQubeScanner'

                    withSonarQubeEnv('MySonarQubeServer') {
                        sh """
                        ${scannerHome}/bin/sonar-scanner \
                        -Dsonar.projectKey=${APP_NAME} \
                        -Dsonar.projectName=${APP_NAME}
                        """
                    }
                }
            }
        }

        stage("🛡️ FS Güvenlik Taraması | Trivy FS Scan") {
            steps {
                sh "trivy fs . > trivyfs.txt"
            }
        }

        stage('🧽 Docker Image Temizleme | Docker Image Clean') {
            steps {
                script {
                    if (isUnix()) {
                        sh "docker image prune -f"
                    } else {
                        bat "docker image prune -f"
                    }
                }
            }
        }

        stage("🚀 Docker Build & Push | Docker İmaj Build ve Push") {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'DockerHubToken4Jenkins', toolName: 'docker') {
                        dir('006-devops-nextjs-kubernetes-jenkins-pipeline') {
                            sh "docker build -t ${IMAGE_NAME}:latest ."
                            sh "docker push ${IMAGE_NAME}:latest"
                        }
                    }
                }
            }
        }

        stage("🔍 Image Güvenlik Taraması | Trivy Image Scan") {
            steps {
                sh "trivy image ${IMAGE_NAME}:latest > trivyimage.txt"
            }
        }

        stage("🚀 Docker Run | Container Deploy") {
            steps {
                script {
                    sh """
                    docker stop nextjs-app || true
                    docker rm nextjs-app || true

                    docker run -d \
                    --name nextjs-app \
                    -p 3000:3000 \
                    ${IMAGE_NAME}:latest
                    """
                }
            }
        }

        stage('☸️ Kubernetes Deploy | Kubernetes’e Dağıtım') {
            steps {
                script {
                    dir('006-devops-nextjs-kubernetes-jenkins-pipeline/kubernetes') {
                        withKubeConfig(
                            caCertificate: '',
                            clusterName: '',
                            contextName: '',
                            credentialsId: 'IdKubernetes',
                            namespace: '',
                            restrictKubeConfigAccess: false,
                            serverUrl: ''
                        ) {
                            sh 'kubectl delete --all pods'
                            sh 'kubectl apply -f deployment.yml'
                            sh 'kubectl apply -f service.yml'
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            emailext(
                attachLog: true,
                mimeType: 'text/html',
                subject: "🚀 [${currentBuild.result}] CI/CD PIPELINE RAPORU | ${env.JOB_NAME} #${env.BUILD_NUMBER}",

                body: """
                <html>
                <body style="margin:0; padding:0; background:#0b1220; font-family:Arial;">

                <div style="max-width:720px; margin:auto; padding:25px;">

                    <div style="background:linear-gradient(90deg,#0ea5e9,#22c55e); padding:20px; border-radius:14px; color:white;">
                        <h1 style="margin:0;">🚀 PIPELINE ÇALIŞMA RAPORU</h1>
                        <p style="margin:5px 0 0;">Gerçek zamanlı DevOps izleme sistemi</p>
                    </div>

                    <div style="margin-top:20px; background:#111827; padding:20px; border-radius:14px; border:1px solid #1f2937;">
                        <h2 style="color:#38bdf8;">📊 Build Özeti</h2>

                        <p>📦 Proje: <b>${env.JOB_NAME}</b></p>
                        <p>🔢 Build Numarası: <b>#${env.BUILD_NUMBER}</b></p>

                        <p>⚡ Durum:
                            <span style="
                                padding:6px 12px;
                                border-radius:8px;
                                background:${currentBuild.result == 'SUCCESS' ? '#16a34a' : '#dc2626'};
                                color:white;
                                font-weight:bold;">
                                ${currentBuild.result}
                            </span>
                        </p>
                    </div>

                    <div style="margin-top:20px; background:#0f172a; padding:20px; border-radius:14px; border:1px solid #1f2937;">
                        <h2 style="color:#fbbf24;">📡 Pipeline Bilgileri</h2>

                        <ul style="color:#cbd5e1; line-height:1.8;">
                            <li>🕒 Çalışma Süresi: ${currentBuild.durationString}</li>
                            <li>🌐 Jenkins URL: <a style="color:#60a5fa;" href="${env.BUILD_URL}">Build’i Aç</a></li>
                            <li>🧪 Trivy FS Taraması: Eklendi</li>
                            <li>🐳 Image Güvenlik Taraması: Eklendi</li>
                        </ul>
                    </div>

                    <div style="margin-top:20px; padding:20px; border-radius:14px;
                        background:${currentBuild.result == 'SUCCESS' ? '#052e16' : '#450a0a'};
                        border:1px solid ${currentBuild.result == 'SUCCESS' ? '#16a34a' : '#dc2626'};">

                        <h2 style="color:white;">🚨 Sistem Durumu</h2>

                        <p style="color:#e5e7eb;">
                            ${currentBuild.result == 'SUCCESS'
                                ? 'Pipeline başarıyla çalıştı. Sistem stabil. 🟢'
                                : 'Pipeline hatası tespit edildi. Acil müdahale gerekli. 🔴'}
                        </p>

                    </div>

                </div>

                </body>
                </html>
                """,

                to: 'huseyinaydin99@gmail.com',
                attachmentsPattern: 'trivyfs.txt,trivyimage.txt'
            )
        }
    }
}